{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    { "src": "/api/checkstatus", "dest": "/api/checkstatus.js" },
    { "src": "/ar", "dest": "/index.html" },
    { "src": "/ar/", "dest": "/index.html" },
    { "src": "/ar/index.html", "dest": "/index.html" },
    { "src": "/ar/moreGames.html", "dest": "/moreGames.html" },
    { "src": "/ar/myAccount.html", "dest": "/myAccount.html" },
    { "src": "/ar/termsAndConditions.html", "dest": "/termsAndConditions.html" },
    { "src": "/ar/(.*)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
